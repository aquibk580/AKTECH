.nav-menu {
    background-color: white;
    width: 360px;
    height: 100vh;
    display: flex;
    justify-content: center;
    position: fixed;
    top:0;
    left: -100%;
    transition: 850ms;
    box-shadow: 0 0 20px ;
    z-index: 1;
}

.nav-menu.active{
    left: 0;
    transition: 350ms;
    z-index: 2;
}

.nav-text{
    display: flex;
    justify-content: start;
    align-items: center;
    padding: 8px 0px 8px 16px;
    list-style: none;
    height: 70px;
    font-weight: 400;
    border-bottom: 0.5px solid black;
}

.nav-text a{
    text-decoration: none;
    color: black;
    font-size: 1.5rem;
    width: 95%;
    height: 100%;
    display: flex;
    align-items: center;
    padding: 0 16px;
    border-radius: 4px;
}

.nav-text:hover {
    background-color: red;
}

.nav-menu-items {
    margin: 0 20px;
    width: 100%;
    list-style: none;
}
.nav-bar-toggle {
    background-color: #060b26;
    width: 100%;
    height: 80px;
    display: flex;
    justify-content: start;
    align-items: center;
}

.sideTitle {
    margin-left:16px;
}
.menu-bars{
    position: relative;
    left:290px;
    top:5px;
    font-size: 1.7rem;
}


@media screen and (max-width:700px){
    .nav-menu{
       width: 260px;
    }
    .nav-menu-items{
        margin: 0;
    }
    .menu-bars{
        left: 210px;
    }
    .nav-text{
        margin: 5px 0;
        height: 60px;
    }
    .nav-text a{
        font-size: 1.2rem;
    }
}