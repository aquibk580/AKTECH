.custom-pc-main{
    padding: 50px 70px;
}

.custom-pc-box-main{
    justify-content: space-around;
}
.custom-pc-box-main button{
     border: none;
     border-radius: 7px;
     height: 6vh;
}
.custom-pc-box{
    padding: 40px 30px;
    margin: 20px 0;
    transition: transform 0.5s ease-in-out;
}
.custom-pc-box:hover{
    box-shadow: rgba(0, 0, 0, 0.35) 0px 5px 15px;
    border-radius: 9px;
    transform: scale(1.05);
}
.in-stock{
  align-items: center;
}
.in-stock p{
    margin:10px 10px;
}
.custom-pc-box-main img{
    width:88vh;
}
.custom-pc-main h4{
   font-weight: 700;
}

.custom-price{
    font-weight: 600;
}


@media screen and (max-width:700px){
    .custom-pc-main{
        position: relative;
        top:110px;
        margin: 0;
    }
    .custom-pc-box{
        padding: 20px 10px;
    }
    .custom-pc-box-main img{
        width: 20vh;
    }
    .custom-pc-box button{
        font-size: 12px;
    }
    .custom-pc-box h6{
       font-size: 15px;
       font-weight: 600;
    }
    .custom-pc-main h4{
        position: relative;
        left: -30px;
        width: 300px;
    }
    .pyfc{
       position: relative;
       left: -30px;
       width: 300px;
    }
    .in-stock{
        font-size: 15px;
    }
    .custom-price{
        font-size: 15px;
    }
}
